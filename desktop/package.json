{
  "name": "cafe-de-paris-pos",
  "version": "1.0.0",
  "description": "Offline cashier POS for Café de Paris",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node -e \"require('fs').mkdirSync('receipt-css',{recursive:true});require('fs').copyFileSync('../ui/static/ui/css/receipt-print.css','receipt-css/receipt-print.css')\"",
    "build": "electron-builder --win",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.cafedeparis.pos",
    "productName": "Café de Paris POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "receipt-css/**/*"
  ],
    "extraFiles": [
      {
        "from": "config.json",
        "to": "config.json"
      }
    ],
    "win": {
      "icon": "build/app_icon.ico",
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  }
}
