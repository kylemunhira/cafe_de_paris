DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# For LAN access: add your machine's IP and run `python manage.py runserver 0.0.0.0:8000`
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.100.69,griffinzim.online
# Full origin URLs (scheme + host + port) so browser login works from other devices
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.100.69:8000,http://griffinzim.online:8000,https://griffinzim.online

# SQLite is used by default. Uncomment for PostgreSQL:
DB_ENGINE=postgresql
DB_NAME=cafe_de_paris
DB_USER=postgres
DB_PASSWORD=@gr1ff1n#
DB_HOST=localhost
DB_PORT=5432

# ZIMRA fiscal device API
#ZIMRA_FISCAL_BASE_URL=http://192.168.100.8:5008
ZIMRA_FISCAL_BASE_URL=http://pos.zimhope.co.zw:5008
ZIMRA_DEFAULT_DEVICE_ID=30541
ZIMRA_SUBMIT_TIMEOUT=30
# Middleware action names (paths: /api/{action}/{device_id})
ZIMRA_GET_STATUS_ACTION=getstatus
ZIMRA_OPEN_DAY_ACTION=openday
ZIMRA_CLOSE_DAY_ACTION=close_day
